---
interface Props {
  title: string;
  description?: string;
}
const { title, description = "Karan Bhalodiya – Lead Software Engineer" } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <script type="text/javascript">
      (function(C,A,L){let p=function(a,ar){a.q.push(ar)};let d=C.document;C.Cal=C.Cal||function(){let cal=C.Cal;let ar=arguments;if(!cal.loaded){cal.ns={};cal.q=cal.q||[];d.head.appendChild(d.createElement("script")).src=A;cal.loaded=true}if(ar[0]===L){const api=function(){p(api,arguments)};const namespace=ar[1];api.q=api.q||[];typeof namespace==="string"?(cal.ns[namespace]=api)&&p(api,ar):p(cal,ar);return}p(cal,ar)};})(window,"https://app.cal.com/embed/embed.js","init");
      Cal("init", { origin: "https://cal.com" });
    </script>
  </head>
  <body>
    <div class="bg-orbs" aria-hidden="true">
      <div class="orb orb-1"></div>
      <div class="orb orb-2"></div>
      <div class="orb orb-3"></div>
      <div class="orb orb-4"></div>
    </div>
    <slot />
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --glass-bg: rgba(15, 15, 35, 0.70);
    --glass-bg-hover: rgba(20, 20, 45, 0.85);
    --glass-border: rgba(255, 255, 0, 0.18);
    --glass-shadow: 0 8px 32px rgba(255, 255, 0, 0.06), 0 2px 8px rgba(0,0,0,0.5);
    --glass-blur: blur(20px);

    --color-bg: #05050f;
    --color-text: #e8e8f0;
    --color-muted: #9090a8;
    --color-subtle: #505068;
    --color-accent: #ffff00;
    --color-accent-2: #00d4ff;
    --color-accent-pink: #ff3dff;
    --font: 'Inter', system-ui, sans-serif;
  }

  body {
    font-family: var(--font);
    background: var(--color-bg);
    color: var(--color-text);
    line-height: 1.6;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Soft pastel orbs — iOS light wallpaper feel */
  .bg-orbs {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }
  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    animation: drift 20s ease-in-out infinite alternate;
  }
  .orb-1 {
    width: 700px; height: 700px;
    background: radial-gradient(circle, rgba(255,255,0,0.18), transparent 70%);
    top: -200px; left: -150px;
    animation-duration: 22s;
  }
  .orb-2 {
    width: 550px; height: 550px;
    background: radial-gradient(circle, rgba(255,61,255,0.14), transparent 70%);
    top: 15%; right: -120px;
    animation-duration: 18s;
    animation-delay: -5s;
  }
  .orb-3 {
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(0,212,255,0.14), transparent 70%);
    bottom: 5%; left: 15%;
    animation-duration: 24s;
    animation-delay: -10s;
  }
  .orb-4 {
    width: 400px; height: 400px;
    background: radial-gradient(circle, rgba(255,255,0,0.10), transparent 70%);
    bottom: -80px; right: 10%;
    animation-duration: 19s;
    animation-delay: -14s;
  }
  @keyframes drift {
    0%   { transform: translate(0, 0) scale(1); }
    33%  { transform: translate(40px, -30px) scale(1.05); }
    66%  { transform: translate(-20px, 40px) scale(0.97); }
    100% { transform: translate(30px, 20px) scale(1.03); }
  }

  a { color: var(--color-accent); text-decoration: none; }
  a:hover { text-decoration: underline; }
</style>
