---
const { active } = Astro.props;
---

<nav class="site-nav">
  <a href="/" class={active === 'home' ? 'nav-link active' : 'nav-link'}>Home</a>
  <a href="/resume" class={active === 'resume' ? 'nav-link nav-link--resume active' : 'nav-link nav-link--resume'}>Resume</a>
  <a href="/blog" class={active === 'blog' ? 'nav-link active' : 'nav-link'}>Blog</a>
  <button
    data-cal-link="karanftd"
    data-cal-origin="https://cal.com"
    class="nav-book"
  >
    Schedule a Meeting
  </button>
</nav>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    display: flex;
    gap: 0.25rem;
    padding: 0.75rem 1.5rem;
    background: rgba(5, 5, 20, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255, 255, 0, 0.12);
    max-width: 100%;
    margin: 0;
  }
  .nav-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: #9090a8;
    padding: 0.35rem 0.85rem;
    border-radius: 50px;
    transition: all 0.15s;
    text-decoration: none;
  }
  .nav-link:hover {
    background: rgba(255, 255, 0, 0.08);
    color: #ffff00;
    text-decoration: none;
  }
  .nav-link.active {
    background: rgba(255, 255, 0, 0.1);
    color: #ffff00;
    font-weight: 600;
  }
  .nav-link--resume {
    background: #ffff00;
    color: #000 !important;
    font-weight: 700;
    padding: 0.35rem 1rem;
  }
  .nav-link--resume:hover {
    background: #e8e800;
    box-shadow: 0 0 16px rgba(255, 255, 0, 0.45);
    text-decoration: none;
  }
  .nav-book {
    margin-left: auto;
    font-family: inherit;
    font-size: 0.875rem;
    font-weight: 600;
    color: #ffff00;
    background: transparent;
    border: 1px solid rgba(255, 255, 0, 0.45);
    padding: 0.35rem 1rem;
    border-radius: 50px;
    cursor: pointer;
    transition: all 0.15s;
  }
  .nav-book:hover {
    background: #ffff00;
    color: #000;
    box-shadow: 0 0 16px rgba(255, 255, 0, 0.35);
  }
</style>
