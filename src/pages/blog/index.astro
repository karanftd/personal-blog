---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function formatDate(date: Date) {
  return date.toLocaleDateString('en-SG', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout title="Blog – Karan Bhalodiya" description="Engineering articles on distributed systems, LLMs, and product engineering.">
  <Nav active="blog" />
  <main>
    <header>
      <h1>Blog</h1>
      <p class="subtitle">Thoughts on distributed systems, AI engineering, and building products at scale.</p>
    </header>

    <div class="post-list">
      {posts.map(post => (
        <a href={`/blog/${post.id}`} class="post-card">
          <div class="post-meta">
            <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
            <div class="tag-list">
              {post.data.tags.slice(0, 3).map(tag => <span class="tag">{tag}</span>)}
            </div>
          </div>
          <h2 class="post-title">{post.data.title}</h2>
          <p class="post-desc">{post.data.description}</p>
          <span class="read-more">Read article →</span>
        </a>
      ))}
    </div>
  </main>
</BaseLayout>

<style>
  main {
    position: relative;
    z-index: 1;
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1.5rem 5rem;
  }

  header { padding: 2.5rem 0 2rem; }

  h1 {
    font-size: 2.25rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--color-text);
  }
  .subtitle {
    margin-top: 0.5rem;
    font-size: 0.975rem;
    color: var(--color-muted);
    line-height: 1.6;
  }

  .post-list { display: flex; flex-direction: column; gap: 1.25rem; }

  .post-card {
    display: block;
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    box-shadow: var(--glass-shadow);
    border-radius: 18px;
    padding: 1.75rem;
    text-decoration: none;
    color: inherit;
    transition: background 0.2s, border-color 0.2s, box-shadow 0.2s, transform 0.2s;
    transform: translateZ(0);
  }
  .post-card:hover {
    background: var(--glass-bg-hover);
    border-color: rgba(255, 255, 0, 0.35);
    box-shadow: 0 0 24px rgba(255,255,0,0.1), 0 12px 40px rgba(0,0,0,0.5);
    transform: translateY(-2px) translateZ(0);
    text-decoration: none;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }
  time { font-size: 0.78rem; color: var(--color-subtle); }

  .tag-list { display: flex; gap: 0.35rem; flex-wrap: wrap; }
  .tag {
    background: rgba(255, 255, 0, 0.07);
    border: 1px solid rgba(255, 255, 0, 0.2);
    color: #ffff00;
    font-size: 0.72rem;
    padding: 0.15rem 0.6rem;
    border-radius: 50px;
  }

  .post-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.35;
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
  }
  .post-desc {
    font-size: 0.9rem;
    color: var(--color-muted);
    line-height: 1.65;
    margin-bottom: 1rem;
  }
  .read-more {
    font-size: 0.825rem;
    font-weight: 600;
    color: var(--color-accent);
  }
</style>
