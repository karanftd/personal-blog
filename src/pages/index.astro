---
import BaseLayout from '../layouts/BaseLayout.astro';

const experience = [
  {
    role: "Lead Software Engineer",
    company: "Pelago by Singapore Airlines",
    location: "Singapore",
    period: "Apr 2020 – Present",
    summary: "Led multiple high-performing engineering initiatives across the Pelago platform from its inception, encompassing the core transactional system (0-to-1 build), global marketplace expansion, and user retention/growth features.",
    tech: ["Python", "Flask", "Celery", "Redis", "PostgreSQL", "AWS ECS", "Ansible", "CircleCI", "ElasticSearch", "Apollo GraphQL", "Firebase"],
    highlights: [
      "Led a team of 5 engineers to design and deliver customer retention and growth systems, increasing annual retention from ~1% to 8–10% (10× improvement).",
      "Built revenue-generating growth loops (referrals, gift cards, affiliate APIs), contributing $1M+ GMV in FY 2024–2025.",
      "Architected a distributed communication platform integrating SendGrid, Twilio, and Firebase with retry, idempotency, and failure recovery via Kafka.",
      "Designed event-driven workflows using Celery + Redis to process ~50K+ async jobs/day with ~200ms processing latency.",
      "Led LLM-based feature development (itinerary generation, content automation) — reduced manual content effort by 60%, improved delivery speed by 2×.",
      "Introduced AI-assisted engineering workflows (code review, test generation, security checks), improving team throughput by 35%.",
      "Led integration of multiple global inventory providers (BeMyGuest, GlobalTix, Rezdy, Viator) — enabling expansion to 60+ countries, 3,200+ destinations, 190K+ products.",
      "Designed and implemented a personalised promotion engine using ML-driven targeting — increased bookings 30× over 6 months, reduced coupon abuse by 30%.",
      "Designed a state-machine-based booking and payment system integrating Stripe and KrisFlyer Miles wallet.",
      "Developed a multi-currency checkout system supporting 12+ currencies for global market expansion.",
    ],
  },
  {
    role: "Sr. Software Engineer (Engineering Productivity)",
    company: "DataRobot",
    location: "Singapore",
    period: "Mar 2019 – Apr 2020",
    summary: "Joined to build an internal developer platform as DataRobot scaled to 500+ engineers globally; focused on CI/CD reliability, cost optimisation, and developer tooling.",
    tech: ["Java", "Spring Boot", "Vue.js", "PostgreSQL", "Redis", "AWS Lambda", "API Gateway", "DynamoDB", "Jenkins"],
    highlights: [
      "Built an automated code review workflow system on AWS Lambda (Java) integrating Jira, GitHub, Jenkins, and Slack — reduced PR review time from 72 hours to under 24 hours.",
      "Reduced AWS expenditure by ~40% through internal productivity tools and automated dev workflows.",
      "Developed a flake detection and quarantine system, slashing infrastructure expenditure by ~$750/day.",
      "Built developer-facing dashboards (Spring Boot + Vue.js) for build health, PR status, and flake visibility.",
    ],
  },
  {
    role: "Software Engineer",
    company: "Shopback",
    location: "Singapore",
    period: "Apr 2018 – Feb 2019",
    summary: "Designed & developed microservices-based RESTful APIs using NodeJS and MongoDB for Shopback GO.",
    tech: ["Node.js", "MongoDB", "AWS ECS", "Docker"],
    highlights: [
      "Designed microservices-based RESTful APIs for the Shopback GO mobile platform, supporting millions of daily transactions at launch.",
      "Created a reusable shared module library and enforced standards via code reviews — maintaining 94%+ code coverage.",
    ],
  },
  {
    role: "Solution Engineer",
    company: "eInfochips (an Arrow Company)",
    location: "Ahmedabad, India",
    period: "Oct 2016 – Mar 2018",
    tech: ["Java", "Spring Boot", "MySQL", "Redis", "Jenkins", "React"],
    highlights: [
      "Introduced Git flow, Docker containerisation, and full CI/CD pipelines, accelerating release velocity by 60%.",
      "Led migration from monolithic architecture to microservices, cutting deployment time by 3× and enabling faster feature releases.",
    ],
  },
  {
    role: "Software Engineer",
    company: "Azoi Inc.",
    location: "Ahmedabad, India",
    period: "Jun 2012 – Oct 2016",
    tech: ["Python", "Flask", "React", "Celery", "Redis", "PostgreSQL", "Jenkins", "Stripe"],
    highlights: [
      "Built RESTful APIs (Flask, MongoDB, Celery, Redis) for a real-time health monitoring platform handling sensitive medical data.",
      "Optimised data transmission using Protobuf and gzip compression, reducing response time by ~300ms.",
    ],
  },
];

const skills = {
  "Infrastructure": ["AWS", "GCP", "Kubernetes", "NGINX", "Docker", "Kafka", "RabbitMQ", "Heroku", "Jenkins", "Gitlab"],
  "Backend / Frontend": ["Python", "NodeJS", "Java", "ReactJS", "CSS", "HTML"],
  "Protocols": ["REST", "GraphQL", "gRPC"],
  "Datastores": ["PostgreSQL", "MongoDB", "MySQL", "Redis"],
  "AI / ML": ["OpenAI GPT-4o", "Claude (Anthropic)", "Gemini Pro", "Pinecone", "pgvector", "GitHub Copilot", "Cursor"],
  "Certifications": ["AWS Developer Associate"],
};

const education = [
  { degree: "MCA", school: "Visvesvaraya Technological University (VTU)", location: "Bangalore, India", period: "2009–2012" },
  { degree: "BCA", school: "Saurashtra University", location: "Gujarat, India", period: "2006–2009" },
];
---

<BaseLayout title="Karan Bhalodiya – Lead Software Engineer">
  <main>
    <!-- Header -->
    <header>
      <div class="header-inner">
        <div class="header-text">
          <h1>Karan Bhalodiya</h1>
          <p class="title">Lead Software Engineer</p>
          <p class="location">Singapore</p>
        </div>
        <nav class="contact-links">
          <a href="mailto:karan.bhalodiya@gmail.com" aria-label="Email">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            karan.bhalodiya@gmail.com
          </a>
          <a href="https://www.linkedin.com/in/karanbhalodiya" target="_blank" rel="noopener" aria-label="LinkedIn">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
            LinkedIn
          </a>
          <a href="tel:+6587769565" aria-label="Phone">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.15 12 19.79 19.79 0 0 1 1.08 3.41 2 2 0 0 1 3.07 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            +65 8776 9565
          </a>
        </nav>
      </div>
    </header>

    <div class="page">

      <!-- Summary -->
      <section>
        <h2 class="section-title">Summary</h2>
        <p class="summary-text">
          Results-driven Lead Software Engineer with 12+ years of experience, including significant tenure in high-growth,
          product-based startups and 0-to-1 platform builds. Proven track record of architecting scalable distributed
          systems, driving engineering productivity, and leading high-performing teams in fast-paced environments.
          Adept at bridging the gap between complex technical execution and strategic product goals to deliver
          user-centric features and millions in rapid revenue growth.
        </p>
      </section>

      <!-- Skills -->
      <section>
        <h2 class="section-title">Skills</h2>
        <div class="skills-grid">
          {Object.entries(skills).map(([category, items]) => (
            <div class="skill-group">
              <span class="skill-category">{category}</span>
              <div class="tag-list">
                {items.map(item => <span class="tag">{item}</span>)}
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Experience -->
      <section>
        <h2 class="section-title">Work Experience</h2>
        <div class="experience-list">
          {experience.map((job) => (
            <article class="job-card">
              <div class="job-header">
                <div>
                  <h3 class="job-role">{job.role}</h3>
                  <div class="job-meta">
                    <span class="job-company">{job.company}</span>
                    <span class="separator">·</span>
                    <span class="job-location">{job.location}</span>
                  </div>
                </div>
                <span class="job-period">{job.period}</span>
              </div>
              {job.summary && <p class="job-summary">{job.summary}</p>}
              <div class="tag-list job-tech">
                {job.tech.map(t => <span class="tag tag--small">{t}</span>)}
              </div>
              <ul class="highlight-list">
                {job.highlights.map(h => <li>{h}</li>)}
              </ul>
            </article>
          ))}
        </div>
      </section>

      <!-- Education -->
      <section>
        <h2 class="section-title">Education</h2>
        <div class="edu-list">
          {education.map(edu => (
            <div class="edu-item">
              <div>
                <span class="edu-degree">{edu.degree}</span>
                <span class="edu-school">{edu.school}</span>
                <span class="edu-location">{edu.location}</span>
              </div>
              <span class="edu-period">{edu.period}</span>
            </div>
          ))}
        </div>
      </section>

    </div>
  </main>
</BaseLayout>

<style>
  main { max-width: 900px; margin: 0 auto; padding: 0 1.5rem 4rem; }

  /* Header */
  header {
    padding: 3rem 0 2rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2.5rem;
  }
  .header-inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    flex-wrap: wrap;
  }
  h1 {
    font-size: 2.25rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, #e2e8f0, var(--color-accent-light));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .title {
    font-size: 1.1rem;
    color: var(--color-accent-light);
    font-weight: 500;
    margin-top: 0.25rem;
  }
  .location {
    font-size: 0.9rem;
    color: var(--color-muted);
    margin-top: 0.2rem;
  }
  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    align-items: flex-end;
  }
  .contact-links a {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.875rem;
    color: var(--color-muted);
    transition: color 0.15s;
  }
  .contact-links a:hover { color: var(--color-accent-light); text-decoration: none; }

  /* Page layout */
  .page { display: flex; flex-direction: column; gap: 2.5rem; }

  /* Section titles */
  .section-title {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  /* Summary */
  .summary-text {
    color: var(--color-muted);
    font-size: 0.975rem;
    line-height: 1.75;
    max-width: 72ch;
  }

  /* Tags */
  .tag-list { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .tag {
    background: var(--color-tag-bg);
    border: 1px solid var(--color-border);
    color: var(--color-muted);
    font-size: 0.8rem;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
  }
  .tag--small { font-size: 0.72rem; padding: 0.15rem 0.5rem; }

  /* Skills */
  .skills-grid { display: flex; flex-direction: column; gap: 0.9rem; }
  .skill-group { display: flex; align-items: flex-start; gap: 1rem; flex-wrap: wrap; }
  .skill-category {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text);
    min-width: 160px;
    padding-top: 0.2rem;
  }

  /* Experience */
  .experience-list { display: flex; flex-direction: column; gap: 1.75rem; }
  .job-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 1.5rem;
  }
  .job-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }
  .job-role { font-size: 1rem; font-weight: 600; color: var(--color-text); }
  .job-meta { display: flex; align-items: center; gap: 0.4rem; margin-top: 0.2rem; }
  .job-company { font-size: 0.875rem; color: var(--color-accent-light); font-weight: 500; }
  .separator { color: var(--color-border); }
  .job-location { font-size: 0.875rem; color: var(--color-muted); }
  .job-period {
    font-size: 0.8rem;
    color: var(--color-muted);
    white-space: nowrap;
    background: var(--color-tag-bg);
    border: 1px solid var(--color-border);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
  }
  .job-summary {
    font-size: 0.875rem;
    color: var(--color-muted);
    font-style: italic;
    margin-bottom: 0.75rem;
    line-height: 1.65;
  }
  .job-tech { margin-bottom: 1rem; }
  .highlight-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .highlight-list li {
    font-size: 0.875rem;
    color: var(--color-muted);
    line-height: 1.65;
    padding-left: 1.1rem;
    position: relative;
  }
  .highlight-list li::before {
    content: "▸";
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-size: 0.75rem;
    top: 0.15rem;
  }

  /* Education */
  .edu-list { display: flex; flex-direction: column; gap: 0.75rem; }
  .edu-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .edu-degree { font-weight: 600; font-size: 0.9rem; margin-right: 0.5rem; }
  .edu-school { font-size: 0.875rem; color: var(--color-accent-light); margin-right: 0.5rem; }
  .edu-location { font-size: 0.8rem; color: var(--color-muted); }
  .edu-period {
    font-size: 0.8rem;
    color: var(--color-muted);
    white-space: nowrap;
    background: var(--color-tag-bg);
    border: 1px solid var(--color-border);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
  }

  @media (max-width: 640px) {
    h1 { font-size: 1.75rem; }
    .header-inner { flex-direction: column; }
    .contact-links { align-items: flex-start; }
    .skill-category { min-width: 100%; }
    .job-header { flex-direction: column; }
  }
</style>
