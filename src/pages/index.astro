---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';

const marqueeText = Array(10).fill('Built with Love & AI').join('  ✦  ') + '  ✦  ';
---

<BaseLayout title="Karan Bhalodiya – Lead Software Engineer">
  <Nav active="home" />

  <div class="page-fill">
  <section class="hero" aria-labelledby="hero-name">
    <h1 id="hero-name">Karan Bhalodiya</h1>
    <p class="hero-title">Lead Software Engineer</p>
    <p class="hero-location">Singapore</p>
  </section>

  <div class="marquee-band" aria-hidden="true">
    <div class="marquee-track">
      <span class="marquee-content">{marqueeText}</span>
      <span class="marquee-content">{marqueeText}</span>
    </div>
  </div>
  </div>
</BaseLayout>

<style>
  .page-fill {
    min-height: 100vh;
    background: #ffff00;
    display: flex;
    flex-direction: column;
    position: relative;
    z-index: 1;
  }

  .hero {
    flex: 1;
    width: 100%;
    padding: clamp(5rem, 10vw, 9rem) 1.5rem clamp(4rem, 8vw, 8rem);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  h1 {
    font-size: clamp(3.5rem, 11vw, 9rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1;
    color: #000;
  }

  .hero-title {
    font-size: clamp(1rem, 2.5vw, 1.6rem);
    font-weight: 600;
    color: #1a1a1a;
    margin-top: 1rem;
  }

  .hero-location {
    font-size: 1rem;
    color: #2a2a2a;
    margin-top: 0.4rem;
    opacity: 0.7;
  }

  .marquee-band {
    overflow: hidden;
    background: #0a0a0a;
    padding: 0.9rem 0;
    width: 100%;
    border-top: 1px solid rgba(255, 255, 0, 0.4);
    border-bottom: 1px solid rgba(255, 255, 0, 0.4);
    position: relative;
    z-index: 1;
  }

  .marquee-track {
    display: flex;
    width: max-content;
    animation: marquee-scroll 35s linear infinite;
  }

  .marquee-content {
    white-space: nowrap;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #ffff00;
    padding-right: 3rem;
  }

  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-track { animation-play-state: paused; }
  }
</style>
